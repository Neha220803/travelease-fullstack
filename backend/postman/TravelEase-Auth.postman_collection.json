{
  "info": {
    "name": "TravelEase - Auth + Health Slice",
    "description": "Tests register/login/me/health against the H2-backed Spring Boot backend. Run 'Login' first (or after 'Register') to auto-populate {{accessToken}} for 'Get Current User'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Reports UP', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Asha Traveler\",\n  \"email\": \"asha@example.com\",\n  \"phone\": \"9999999999\",\n  \"password\": \"Passw0rd1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Returns the created user', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.email).to.eql('asha@example.com');",
              "    pm.expect(body.data.role).to.eql('ROLE_TRAVELER');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register - Duplicate Email (expect 409)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Asha Traveler\",\n  \"email\": \"asha@example.com\",\n  \"phone\": \"9999999999\",\n  \"password\": \"Passw0rd1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 409', () => pm.response.to.have.status(409));",
              "pm.test('Error code is DUPLICATE_RESOURCE', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.false;",
              "    pm.expect(body.error.code).to.eql('DUPLICATE_RESOURCE');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register - Invalid Payload (expect 400)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"\",\n  \"email\": \"not-an-email\",\n  \"phone\": \"9999999999\",\n  \"password\": \"short\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 400', () => pm.response.to.have.status(400));",
              "pm.test('Error code is VALIDATION_ERROR', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.error.code).to.eql('VALIDATION_ERROR');",
              "    pm.expect(body.error.details.length).to.be.greaterThan(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"asha@example.com\",\n  \"password\": \"Passw0rd1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns an access token', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "if (body.data && body.data.accessToken) {",
              "    pm.collectionVariables.set('accessToken', body.data.accessToken);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Login - Wrong Password (expect 401)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"asha@example.com\",\n  \"password\": \"WrongPassword1\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', () => pm.response.to.have.status(401));",
              "pm.test('Error code is INVALID_CREDENTIALS', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.error.code).to.eql('INVALID_CREDENTIALS');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Current User (Me)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns the logged-in user', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.email).to.eql('asha@example.com');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Current User - No Token (expect 401)",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', () => pm.response.to.have.status(401));"
            ]
          }
        }
      ]
    }
  ]
}
