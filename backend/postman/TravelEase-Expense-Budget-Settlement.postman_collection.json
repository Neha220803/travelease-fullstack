{
  "info": {
    "name": "TravelEase - Expense Budget Settlement",
    "description": "Tests the seeded demo trip expense, budget, and settlement APIs. Run 'Login - Demo Alice' first to populate {{accessToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "tripId", "value": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa", "type": "string" },
    { "key": "aliceId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "bobId", "value": "22222222-2222-2222-2222-222222222222", "type": "string" },
    { "key": "caraId", "value": "33333333-3333-3333-3333-333333333333", "type": "string" },
    { "key": "expenseId", "value": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb", "type": "string" },
    { "key": "settlementId", "value": "cccccccc-cccc-cccc-cccc-cccccccccccc", "type": "string" }
  ],
  "item": [
    {
      "name": "Login - Demo Alice",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@travelease.test\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns Alice access token', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.user.email).to.eql('alice@travelease.test');",
              "    pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
              "});",
              "if (body.data && body.data.accessToken) {",
              "    pm.collectionVariables.set('accessToken', body.data.accessToken);",
              "    pm.collectionVariables.set('aliceId', String(body.data.user.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Expenses - List Trip Expenses",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/expenses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "expenses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns expenses array', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data).to.be.an('array');",
              "});",
              "if (body.data && body.data.length > 0) {",
              "    pm.collectionVariables.set('expenseId', String(body.data[0].id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Expenses - Get Expense By ID",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/expenses/{{expenseId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "expenses", "{{expenseId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns selected expense', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(String(body.data.id)).to.eql(pm.collectionVariables.get('expenseId'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Expenses - Create Shared Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 450,\n  \"category\": \"Food\",\n  \"description\": \"Lunch by Bob\",\n  \"payerId\": \"{{bobId}}\",\n  \"participantIds\": [\"{{aliceId}}\", \"{{bobId}}\", \"{{caraId}}\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/expenses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "expenses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('Creates shared expense', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.amount).to.eql(450);",
              "    pm.expect(body.data.participants.length).to.eql(3);",
              "});",
              "if (body.data && body.data.id) {",
              "    pm.collectionVariables.set('expenseId', String(body.data.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Expenses - Create Custom Share Expense",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 600,\n  \"category\": \"Transport\",\n  \"description\": \"Taxi with custom shares\",\n  \"payerId\": \"{{aliceId}}\",\n  \"participantIds\": [\"{{aliceId}}\", \"{{bobId}}\", \"{{caraId}}\"],\n  \"participantShares\": [\n    { \"userId\": \"{{aliceId}}\", \"shareAmount\": 100 },\n    { \"userId\": \"{{bobId}}\", \"shareAmount\": 250 },\n    { \"userId\": \"{{caraId}}\", \"shareAmount\": 250 }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/expenses",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "expenses"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('Creates custom share expense', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.amount).to.eql(600);",
              "    pm.expect(body.data.participants.length).to.eql(3);",
              "    const totalShare = body.data.participants.reduce((sum, participant) => sum + participant.shareAmount, 0);",
              "    pm.expect(totalShare).to.eql(600);",
              "});",
              "if (body.data && body.data.id) {",
              "    pm.collectionVariables.set('expenseId', String(body.data.id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Budget - My Usage",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/budget/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "budget", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns my budget usage', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.tripId).to.eql(pm.collectionVariables.get('tripId'));",
              "    pm.expect(body.data).to.have.property('remainingAmount');",
              "    pm.expect(body.data).to.have.property('utilizationPercentage');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Budget - Trip Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/budget/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "budget", "summary"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns trip budget summary', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data).to.have.property('totalBudget');",
              "    pm.expect(body.data).to.have.property('totalSpent');",
              "    pm.expect(body.data.members).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Settlements - Mine",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/settlements/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "settlements", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns my settlements', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data).to.be.an('array');",
              "});",
              "if (body.data && body.data.length > 0) {",
              "    pm.collectionVariables.set('settlementId', String(body.data[0].id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Settlements - Trip Summary",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/trips/{{tripId}}/settlements/summary",
          "host": ["{{baseUrl}}"],
          "path": ["api", "trips", "{{tripId}}", "settlements", "summary"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Returns settlement summary', () => {",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.settlements).to.be.an('array');",
              "});",
              "if (body.data && body.data.settlements && body.data.settlements.length > 0) {",
              "    pm.collectionVariables.set('settlementId', String(body.data.settlements[0].id));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Settlements - Mark Paid",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": {
          "raw": "{{baseUrl}}/api/settlements/{{settlementId}}/paid",
          "host": ["{{baseUrl}}"],
          "path": ["api", "settlements", "{{settlementId}}", "paid"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Marks settlement as paid', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.success).to.be.true;",
              "    pm.expect(body.data.status).to.eql('PAID');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
